$mb="Insertmailboxname@TestDomain.com"; $csv="C:\Temp\SharedMailboxPermissions.csv"; (Get-MailboxPermission $mb | Where-Object {$_.User -notlike "NT AUTHORITY\SELF" -and $_.AccessRights -contains "FullAccess"} | Select-Object @{n="Mailbox";e={$mb}}, @{n="Permission";e={"Full Access"}}, @{n="GrantedTo";e={$_.User}}) + (Get-RecipientPermission $mb | Where-Object {$_.Trustee -ne "NT AUTHORITY\SELF" -and $_.AccessRights -contains "SendAs"} | Select-Object @{n="Mailbox";e={$mb}}, @{n="Permission";e={"Send As"}}, @{n="GrantedTo";e={$_.Trustee}}) + ((Get-Mailbox $mb).GrantSendOnBehalfTo | Select-Object @{n="Mailbox";e={$mb}}, @{n="Permission";e={"Send on Behalf"}}, @{n="GrantedTo";e={$_}}) | Export-Csv $csv -NoTypeInformation -Encoding UTF8
